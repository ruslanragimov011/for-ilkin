import pygame
import json

pygame.init()

WIDTH = 800
HEIGHT = 800
game_over = 0
FPS = 60
score = 0
sound_jump = pygame.mixer.Sound("music/jump.wav")
sound_gameover = pygame.mixer.Sound("music/game_over.wav")
sound_coin = pygame.mixer.Sound("music/coin.wav")

display = pygame.display.set_mode((WIDTH, HEIGHT,))
pygame.display.set_caption("Ruslan game")
clock = pygame.time.Clock()

background_image = pygame.image.load("images/bg11.png")
background_rect = background_image.get_rect()
# with open("levels/level1.json") as file:
#     world_data = json.load(file)
level = 1
max_level = 4
def reset_level():
    player.rect.x = 100
    player.rect.y = HEIGHT - 130
    lava_group.empty()
    exit_group.empty()
    with open(f"levels/level{level}.json") as file:
        world_data = json.load(file)
    world = World(world_data)
    return world

tile_size = 40


class Coin(pygame.sprite.Sprite):
    def __init__(self,x ,y):
        super().__init__()
        self.image = pygame.image.load("images/coin.png")
        self.rect = self.image.get_rect()
        self.rect.center = x, y

coin_group = pygame.sprite.Group()


class Lava(pygame.sprite.Sprite):
    def __init__(self,x , y ):
        super().__init__()
        self.image = pygame.image.load("images/lava.png")
        self.image = pygame.transform.scale(self.image, (tile_size , tile_size // 2))
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
lava_group = pygame.sprite.Group()

class Button :
    def __init__(self, x,y , image ):
        self.image = pygame.image.load(image)
        self.rect = self.image.get_rect(center=(x,y))
    def draw(self):
        action = False
        if self.rect.collidepoint(pygame.mouse.get_pos()):
            if pygame.mouse.get_pressed()[0] == 1:
                action = True
        display.blit(self.image, self.rect)
        return action

restart_button = Button(WIDTH // 2,HEIGHT // 2 ,"images/restart_btn 7.png")
start_button = Button(WIDTH// 2 - 200,HEIGHT // 2 , image="images/start_btn 7.png")
exit_button = Button(WIDTH// 2 + 200, HEIGHT// 2 , image="images/exit_btn 7.png")

class Exit(pygame.sprite.Sprite):
    def __init__(self,x , y ):
        super().__init__()
        dor = pygame.image.load("images/door1.png")
        self.image = pygame.transform.scale(dor , (tile_size , tile_size * 1.5))
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y

exit_group = pygame.sprite.Group()


class World:
    def __init__(self, data):
        dirt_img = pygame.image.load("images/dirt.png")
        grass_img = pygame.image.load("images/grass.png")
        self.tile_list = []
        row_count = 0
        for row in data :
            coll_count = 0
            for tile in row:
                if tile == 1 or tile == 2:
                    images = {1:dirt_img,2:grass_img}


                    img = pygame.transform.scale(images[tile],(tile_size,tile_size))
                    img_rect = img.get_rect()
                    img_rect.x = coll_count * tile_size
                    img_rect.y = row_count * tile_size
                    tile = (img,img_rect)
                    self.tile_list.append(tile)
                elif tile == 3:
                    lava = Lava(coll_count * tile_size , row_count * tile_size + tile_size // 2 )
                    lava_group.add(lava)
                elif tile == 5:
                    exit = Exit(coll_count * tile_size, row_count * tile_size - tile_size // 2)
                    exit_group.add(exit)
                elif tile ==6:
                    coin = Coin(coll_count * tile_size - tile_size // 2, row_count * tile_size - tile_size // 2)
                    coin_group.add(coin)

                coll_count += 1
            row_count += 1

    def draw(self):
        for tile in self.tile_list:
            display.blit(tile[0], tile[1])

def draw_text(text,color,size,x,y):
    font = pygame.font.SysFont("Arial",size)
    img = font.render(text,True,color)
    display.blit(img,(x,y))



class Player:
    def __init__(self):
        self.images_right = []
        self.images_left = []
        self.index = 0
        self.counter = 0
        self.direction = "right"
        for num in range(1, 5):
            self.image = pygame.image.load(f"images/player{num}.png")
            self.image_right = pygame.transform.scale(self.image, (35, 70))
            self.image_left = pygame.transform.flip(self.image_right, True , False)
            self.images_right.append(self.image_right)
            self.images_left.append(self.image_left)

        self.image = self.images_right[self.index]
        self.rect = self.image.get_rect()
        self.rect.x = 100
        self.rect.y = HEIGHT - 130
        self.gravity = 0
        self.jumped = False
        self.width = self.image.get_width()
        self.height = self.image.get_height()





    def update(self):
        global game_over
        x = 0
        y = 0
        walk_speed = 10
        if game_over == 0 :
            if self.counter >= walk_speed:
                if self.index >= len(self.images_right) - 1:
                    self.index = 0
                else:
                    self.index += 1
                self.counter = 0
                if self.direction == "right":
                    self.image = self.images_right[self.index]
                elif self.direction == "left":
                    self.image = self.images_left[self.index]

            self.gravity += 1
            if self.gravity > 10:
                self.gravity = 10

            key = pygame.key.get_pressed()
            if key[pygame.K_a]:
                x -= 5
                self.counter += 1
                self.direction = "left"
            if key[pygame.K_d]:
                x += 5
                self.counter += 1
                self.direction = "right"
            if key[pygame.K_SPACE] and not self.jumped:
                self.gravity = -15
                self.jumped = True
                sound_jump.play()
            y += self.gravity
            for tile in world.tile_list:
                if tile[1].colliderect(self.rect.x + x, self.rect.y, self.width, self.height):
                    x = 0
                if tile[1].colliderect(self.rect.x, self.rect.y + y, self.width, self.height):
                    if self.gravity < 0:
                        y = tile[1].bottom - self.rect.top
                        self.gravity = 0
                    elif self.gravity >= 0:
                        y = tile[1].top - self.rect.bottom
                        self.gravity = 0
                        self.jumped = False

            if pygame.sprite.spritecollide(self, lava_group, False):
                game_over = -1
            elif pygame.sprite.spritecollide(self,exit_group,False):
                game_over = 1
            if self.rect.bottom > HEIGHT:
                self.rect.bottom = HEIGHT
                self.jumped = False

            coins_collected = pygame.sprite.spritecollide(self, coin_group, True)
            if coins_collected:
                print(f"{coins_collected}")



            self.rect.x += x
            self.rect.y += y
        elif game_over == -1 :
            print("Game over")
            ghost = pygame.image.load("images/ghost.png")
            sound_gameover.play()
            self.image = pygame.transform.scale(ghost,(35,70))
            self.rect.y -= 5
        display.blit(self.image, self.rect)

