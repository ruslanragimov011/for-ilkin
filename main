# car = Car()
player = Player()
# world = World(world_data)
main_menu = True

run = True
while run:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            run = False

    display.blit(background_image, background_rect)
    if main_menu:
        if start_button.draw():
            score = 0
            level = 1
            world = reset_level()
            main_menu = False
        if exit_button.draw():

            run = False
    else:
        player.update()
        # car.update()
        world.draw()
        draw_text(str(score),(255,255,255),30,10,10)
        if pygame.sprite.spritecollide(player, coin_group, True):
            score += 1
            print(score)
            sound_coin.play()

        if game_over == -1:
            if restart_button.draw():
                player = Player()
                world = reset_level()
                # world = World(world_data)
                game_over = 0
        elif game_over == 1:

            if level < max_level:
                level += 1
            else:
                print("you win")
                main_menu = True
            world = reset_level()
            game_over = 0

        lava_group.draw(display)
        lava_group.update()
        exit_group.draw(display)
        exit_group.update()
        coin_group.draw(display)
        coin_group.update()
    pygame.display.update()
    clock.tick(FPS)
pygame.quit()
